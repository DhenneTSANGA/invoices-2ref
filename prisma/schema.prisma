generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Cabinet {
  conseil
  expertise_fiscale
}

enum DocumentType {
  quotation
  invoice
  proforma
  letter
}

enum DocumentStatus {
  draft
  sent
  accepted
  rejected
  paid
  overdue
  archived
  cancelled
}

enum ActivityKind {
  invoice_paid
  invoice_sent
  invoice_overdue
  quotation_accepted
  quotation_sent
  client_added
}

enum NotificationType {
  info
  success
  warning
  danger
}

enum StaffRole {
  member
  admin
  super_admin
}

enum AdminRequestStatus {
  pending
  accepted
  rejected
}

model Company {
  id          String   @id @default(cuid())
  cabinet     Cabinet  @unique
  name        String
  tagline     String?
  nif         String
  niu         String
  rccm        String
  cnss        String?
  address     String
  city        String
  phone       String
  email       String
  website     String?
  bankName    String?
  bankAccount String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("companies")
}

model StaffMember {
  id        String    @id
  email     String    @unique
  firstName String
  lastName  String
  jobTitle  String
  phone     String?
  avatarUrl String?
  role      StaffRole @default(member)
  /// Null uniquement pour super_admin (au-dessus des cabinets).
  cabinet   Cabinet?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  documents     Document[]
  notifications Notification[]
  adminRequests AdminRequest[] @relation("AdminRequestStaff")
  reviewedRequests AdminRequest[] @relation("AdminRequestReviewer")

  @@index([lastName])
  @@index([role])
  @@index([cabinet])
  @@map("staff_members")
}

model AdminRequest {
  id           String             @id @default(cuid())
  staffId      String
  status       AdminRequestStatus @default(pending)
  createdAt    DateTime           @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  staff      StaffMember  @relation("AdminRequestStaff", fields: [staffId], references: [id], onDelete: Cascade)
  reviewedBy StaffMember? @relation("AdminRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([staffId, status])
  @@index([status, createdAt])
  @@map("admin_requests")
}

model Client {
  id          String   @id @default(cuid())
  cabinet     Cabinet
  name        String
  legalForm   String
  nif         String
  niu         String
  rccm        String
  contactName String
  email       String
  phone       String
  address     String
  city        String
  country     String   @default("Gabon")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]

  @@index([cabinet])
  @@index([name])
  @@index([city])
  @@map("clients")
}

model Service {
  id          String   @id @default(cuid())
  cabinet     Cabinet
  code        String
  name        String
  description String   @default("")
  unit        String
  unitPrice   Decimal  @db.Decimal(18, 2)
  vatRate     Decimal  @db.Decimal(5, 2)
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines DocumentLine[]

  @@unique([cabinet, code])
  @@index([cabinet])
  @@index([category])
  @@map("services")
}

model Document {
  id                String         @id @default(cuid())
  cabinet           Cabinet
  type              DocumentType
  number            String
  clientId          String
  createdById       String
  status            DocumentStatus @default(draft)
  issueDate         DateTime       @db.Date
  dueDate           DateTime       @db.Date
  subtotal          Decimal        @db.Decimal(18, 2)
  tps               Decimal        @default(0) @db.Decimal(18, 2)
  css               Decimal        @default(0) @db.Decimal(18, 2)
  vat               Decimal        @db.Decimal(18, 2)
  total             Decimal        @db.Decimal(18, 2)
  currency          String         @default("XAF")
  notes             String?
  paymentTerms      String?
  validityDays      Int?
  executionTerms    String?
  incoterm          String?
  shippingNotes     String?
  disclaimer        String?
  subject           String?
  salutation        String?
  body              String?
  closing           String?
  signatoryTitle    String?
  recipientOverride String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy     StaffMember    @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lines         DocumentLine[]
  notifications Notification[]

  @@unique([cabinet, type, number])
  @@index([cabinet])
  @@index([clientId])
  @@index([createdById])
  @@index([status])
  @@index([type])
  @@index([issueDate])
  @@map("documents")
}

model DocumentLine {
  id          String  @id @default(cuid())
  documentId  String
  serviceId   String?
  description String
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  vatRate     Decimal @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  tpsRate     Decimal @default(0) @db.Decimal(5, 2)
  cssRate     Decimal @default(0) @db.Decimal(5, 2)
  position    Int     @default(0)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([serviceId])
  @@map("document_lines")
}

model Activity {
  id          String       @id @default(cuid())
  kind        ActivityKind
  title       String
  description String
  at          DateTime     @default(now())

  @@index([at])
  @@map("activities")
}

model Notification {
  id         String           @id @default(cuid())
  staffId    String
  title      String
  body       String
  at         DateTime         @default(now())
  read       Boolean          @default(false)
  type       NotificationType @default(info)
  documentId String?

  staff    StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  document Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([staffId, read])
  @@index([staffId, at])
  @@map("notifications")
}
